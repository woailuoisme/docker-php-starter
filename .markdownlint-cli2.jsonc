{
  "config": {
    "default": true,
    // 禁用行长度限制（因为中文长段落折行不便且影响移动端连续阅读）
    "MD013": false,
    // 仅在同级标题间检查重复（不同章节下的相同子标题不应报错）
    "MD024": {
      "siblings_only": true
    },
    // 允许内嵌 HTML（以便使用 details 标签折叠大段内容或进行自定义排版）
    "MD033": false,
    // 允许单行强调（有时排版需要轻量级的文本加粗作为段落指引而非正式标题）
    "MD036": false,
    // 允许文档首行不是一级标题（文档可能包含前置元数据或徽章）
    "MD041": false
  },
  // 忽略三方依赖与工具生成的 markdown 文件，避免干扰分析
  "ignores": [
    ".gemini/**",
    ".claude/**",
    ".antigravity/**",
    ".vscode/**",
    "vendor/**",
    "node_modules/**"
  ]
}